# Copy to .env and fill in values

# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=change_me_32_chars_minimum

# Resend API key — get from resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email the system sends FROM (must be a verified Resend domain)
RESEND_FROM=FocusLock <noreply@focuslock.app>

# Port
PORT=3000

# SQLite database path
DB_PATH=./focuslock.db

# OTP valid for N seconds (86400 = 24h)
OTP_TTL_SECONDS=86400

# Rate limit: max unlock requests per user per day
DAILY_UNLOCK_MAX=5
